variable                    pnx     equal 15
variable                    pny     equal 20
variable                    pnz     equal 20
variable                    T       equal 300
variable                    R       equal 984523
variable                    bnx     equal 54
variable                    bny     equal 50
variable                    bnz     equal 50
variable                    nx      equal ${pnx}*${bnx}
variable                    nx      equal 15*${bnx}
variable                    nx      equal 15*54
variable                    ny      equal ${pny}*${bny}
variable                    ny      equal 20*${bny}
variable                    ny      equal 20*50
variable                    nz      equal ${pnz}*${bnz}
variable                    nz      equal 20*${bnz}
variable                    nz      equal 20*50
variable                    model   string /home/export/online1/mdt00/shisuan/swustcfd/oyyc/sc24/W.mar28.npz

processors                  ${pnx} ${pny} ${pnz}
processors                  15 ${pny} ${pnz}
processors                  15 20 ${pnz}
processors                  15 20 20

units                       metal
dimension                   3
boundary                    p p p
atom_style                  atomic
atom_modify                 id no

lattice                     bcc 3.1887
