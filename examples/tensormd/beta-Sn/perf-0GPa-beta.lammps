
units           metal
boundary        p p p
atom_style      atomic
newton          on
read_data       in.data
replicate       ${nx} ${nx} ${nx}
pair_style      tensormd
pair_coeff      * * ../../../potentials/tensormd/Sn_lda1_fp${precision}.npz Sn
neighbor        2.0 bin
neigh_modify	delay 0 every 1 check yes
fix             1 all nve
thermo_style    custom step cpu etotal vol pxx pyy pzz
thermo          10
timestep        0.001
run             100
