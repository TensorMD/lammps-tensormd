variable  newton_pair     index  on
variable  newton_bond     index  off
variable  units           index  metal
variable  input_dir       index  .
variable  data_file       index ${input_dir}/data.tensormd.1
variable  pair_style      index 'zero 8.0'

atom_style       atomic
atom_modify      map array
neigh_modify     delay 2 every 1 check no
units            ${units}
timestep         0.0001
newton           ${newton_pair} ${newton_bond}

pair_style       ${pair_style}
read_data        ${data_file}
