# 编译命令示例
module use /public/software/modules
module load compiler/rocm/dtk/22.10.1
module load compiler/cmake/3.24.1
module load compiler/llvm-openmp/openmp

export CC=mpicc
export CXX=mpicxx

cmake ../cmake \
    -C ../cmake/presets/tensormd.cmake \
    -D BLAS_INCLUDE_DIRS="/public/software/mathlib/openblas/0.3.7/include" \
    -D CMAKE_BUILD_TYPE=Release \
    -D BUILD_MPI=yes \
    -D BUILD_OMP=yes \
    -D BUILD_HIP=yes \
    -D BUILD_CUDA=no \
    -D USE_MKL_BATCH=yes \
    -D LINK_SHARED=no

CC={mpicc, mpiicx}
CXX={mpicxx, mpiipcx}
LINK_SHARED用于选择GPU部分与lammps动态链接或是静态链接
BUILD_CUDA与BUILD_HIP用于选择不同的框架. 若使用Blas, 则需要设置BLAS_INCLUDE_DIRS; 若使用MKL, 可删除BLAS_INCLUDE_DIRS


# 运行命令示例

#!/bin/bash
#SBATCH --partition=normal
#SBATCH --time=02:00:00
#SBATCH --nodes=1
#SBATCH --cpus-per-task=4
#SBATCH --ntasks-per-node=4
#SBATCH --gres=dcu:4

export OMP_NUM_THREADS=4
mpirun /public/home/aicao/oyyc/lammps/build/lmp -in tdnp_in.lammps -log tdnp_log.lammps

mpirun -np 1 /home/oyyc/lammps/build/lmp -pk omp $OMP_NUM_THREADS neigh yes -in in.lammps -log log.lammps

